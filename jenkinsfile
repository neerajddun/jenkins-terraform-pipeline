pipeline {

  environment {
    dockerimagename = "neeraj91/react-app"
    dockerImage = ""
    KUBECONFIG      = "/var/lib/jenkins/.kube/config"
  }

  agent any

  stages {

    stage('Checkout Source') {
      steps {
        git 'https://github.com/neerajddun/jenkins-kubernetes-deployment.git'
      }
    }
/*
    stage('SonarQube Analysis') {
      steps {
        script {
          def scannerHome = tool 'sonar-scanner'
          withSonarQubeEnv('SonarQube') {
            sh """
              ${scannerHome}/bin/sonar-scanner \
              -Dsonar.projectKey=react-app \
              -Dsonar.projectName='React App' \
              -Dsonar.sources=.
            """
          }
        }
      }
    }

    stage('Quality Gate') {
      steps {
        timeout(time: 5, unit: 'MINUTES') {
          waitForQualityGate abortPipeline: true
        }
      }
    }

*/
    stage('Build image') {
    steps {
        dir('demo') {
            script {
                dockerImage = docker.build("${dockerimagename}")
            }
        }
    }
}

stage('Pushing Image') {
    environment {
        registryCredential = 'dockerhub-credentials'
    }
    steps {
        dir('demo') {
            script {
                docker.withRegistry('https://registry.hub.docker.com', registryCredential) {
                    dockerImage.push("latest")
                }
            }
        }
    }
}

stage('Terraform') {
    steps {
        dir('demo/terraform') {
            sh 'terraform init'
            sh 'terraform validate'
            sh 'terraform plan'
            sh 'terraform apply -auto-approve'
        }
    }
}

stage('upload arifacts to s3')
{
  steps {
    dir('demo') {
       sh 'aws s3 sync demo/ s3://neeraj-react-artifacts-1234/builds/${BUILD_ID}/ --exclude ".terraform/*" --exclude "*.tfstate*" --exclude ".git/*"'
    }
  }
}

    stage('Deploy to Kubernetes') {
      steps {
        dir('demo'){
            script {

          sh "kubectl apply -f deployment.yaml "
          sh "kubectl apply -f service.yaml "
            }
        }
      }
    }
  }

  post {

    always {

      cleanWs()
    }
  }
}