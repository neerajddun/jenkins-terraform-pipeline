pipeline {

  environment {
    dockerimagename = "neeraj91/react-app"

  }

  agent any

  stages {

    stage('Checkout Source') {
      steps {
        git 'https://github.com/neerajddun/jenkins-kubernetes-deployment.git'
      }
    }
/*
    stage('SonarQube Analysis') {
      steps {
        script {
          def scannerHome = tool 'sonar-scanner'
